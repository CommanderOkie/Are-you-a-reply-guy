# ─── Twitter/X Cookie Farm ───
# Get these from your burner X account(s):
#   1. Log into x.com in Chrome
#   2. F12 → Application → Cookies → https://x.com
#   3. Copy the values of auth_token and ct0
#   4. Paste them below in the format shown
#
# You can add multiple cookies for load balancing:
TWITTER_COOKIES_1="auth_token=YOUR_AUTH_TOKEN_HERE; ct0=YOUR_CT0_HERE"
TWITTER_COOKIES_2="auth_token=YOUR_AUTH_TOKEN_HERE; ct0=YOUR_CT0_HERE"

# ─── Redis (Optional) ───
# For global stats counter and result caching.
# Get a free instance from Upstash or Redis Cloud.
REDIS_URL="redis://default:xxxxx@xxxxx.upstash.io:6379"
